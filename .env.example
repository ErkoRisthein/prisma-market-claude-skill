# Prisma Market configuration
# Copy to .env and fill in your values: cp .env.example .env

# Store
PRISMA_STORE_ID=542860184              # Kristiine Prisma

# Authentication (Smart-ID / Mobile-ID / ID-card)
PRISMA_AUTH_METHOD=smart-id            # smart-id | mobile-id | id-card
PRISMA_PERSONAL_CODE=39901011234       # Estonian personal ID code (isikukood)
PRISMA_PHONE=+37255512345             # Required only for mobile-id

# Delivery details (required for checkout)
PRISMA_FIRST_NAME=Jaan
PRISMA_LAST_NAME=Tamm
PRISMA_PHONE=+37255512345
PRISMA_EMAIL=jaan.tamm@example.com
PRISMA_DELIVERY_ADDRESS="Pärnu mnt 10, 10148 Tallinn"
PRISMA_APARTMENT=42
PRISMA_DRIVER_INFO="3. korrus"

# Auto-set after login — do not fill manually
# PRISMA_TOKEN=
